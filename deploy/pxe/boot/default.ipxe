#!ipxe
# HTKIS HyperDisk X - iPXE Boot Script (Alpha V1)
# Uses wimboot to boot WinPE from HTTP

echo HTKIS HyperDisk X - iPXE Boot Script
echo ======================================
echo Loading WinPE via wimboot...

kernel http://192.168.2.80/boot/winpe/wimboot
initrd http://192.168.2.80/boot/winpe/bootmgr.exe   bootmgr.exe
initrd http://192.168.2.80/boot/winpe/bootmgfw.efi  bootmgfw.efi
initrd http://192.168.2.80/boot/winpe/boot.sdi      boot.sdi
initrd http://192.168.2.80/boot/winpe/bcd_uefi      BCD
initrd http://192.168.2.80/boot/winpe/boot.wim      boot.wim

echo Starting WinPE...
boot
